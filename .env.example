# ──────────────────────────────────────────────────────────────
# MedConnect Oriental — Environment Configuration
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────

# Database
DB_USER=medadmin
DB_PASSWORD=securepass123

# AES-256-GCM Encryption Key (64-character hex = 256-bit key)
# Generate with: openssl rand -hex 32
AES_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# JWT Secret (REQUIRED - minimum 32 characters for security)
# Generate with: openssl rand -base64 32
# JWT Secret (Must be 32+ characters)
JWT_SECRET=generate-your-secure-32-char-secret-here

# CORS Allowed Origins (comma-separated)
# Example: http://localhost:5173,http://localhost:3000,https://medconnect.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# WhatsApp Gateway (Evolution API)
WA_URL=http://localhost:8080
WA_TOKEN=secret-whatsapp-token
WA_INSTANCE=medconnect

# Ollama
OLLAMA_URL=http://localhost:11434
